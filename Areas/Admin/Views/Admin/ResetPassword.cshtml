@model MyMvcApp.ViewModels.AdminResetPasswordViewModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu cho người dùng";
}

<div class="container-fluid">
    <div class="row">
        <partial name="_AdminSidebar" />

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">@ViewData["Title"]</h1>
            </div>

            <div class="row">
                <div class="col-lg-6">
                    <div class="card shadow mb-4">
                        <div class="card-header">
                            <h6 class="m-0 font-weight-bold text-primary">Đặt lại mật khẩu cho: @Model.Email</h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="ResetPassword" asp-controller="Admin" method="post">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                                <input type="hidden" asp-for="UserId" />
                                <input type="hidden" asp-for="Email" />

                                <div class="mb-3">
                                    <label asp-for="NewPassword" class="form-label"></label>
                                    <input asp-for="NewPassword" class="form-control" />
                                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label"></label>
                                    <input asp-for="ConfirmPassword" class="form-control" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>

                                <div class="d-flex justify-content-end">
                                    <a asp-action="UserManagement" class="btn btn-secondary me-2">Hủy</a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save me-2"></i>Đặt lại mật khẩu
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
