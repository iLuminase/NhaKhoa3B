@model IEnumerable<MyMvcApp.ViewModels.UserManagementViewModel>
@{
    ViewData["Title"] = "Quản lý người dùng";
}

@section Styles {
    <link href="https://cdn.datatables.net/1.11.5/css/dataTables.bootstrap5.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet">
}

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <partial name="_AdminSidebar" />

        <!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">@ViewData["Title"]</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="@Url.Action("CreateUser", "Admin")" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Tạo người dùng mới
                    </a>
                </div>
            </div>

            <!-- User List -->
            <div class="card shadow mb-4">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered" id="userTable" width="100%" cellspacing="0">
                            <thead>
                                <tr>
                                    <th>Tên người dùng</th>
                                    <th>Email</th>
                                    <th>Ngày tạo</th>
                                    <th>Trạng thái</th>
                                    <th>Vai trò</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr>
                                        <td>@user.FullName</td>
                                        <td>@user.Email</td>
                                        <td>@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")">
                                                @(user.IsActive ? "Đang hoạt động" : "Ngừng hoạt động")
                                            </span>
                                        </td>
                                        <td>@string.Join(", ", user.RoleNames)</td>
                                        <td>
                                                <a href="@Url.Action("EditUser", "Admin", new { id = user.Id })"
                                                   class="btn btn-sm btn-primary" title="Chỉnh sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="@Url.Action("ResetPassword", "Admin", new { userId = user.Id })"
                                                   class="btn btn-sm btn-secondary" title="Đặt lại mật khẩu">
                                                    <i class="fas fa-key"></i>
                                                </a>
                                                <button type="button"
                                                        class="btn btn-sm @(user.IsActive ? "btn-warning" : "btn-success")"
                                                        onclick="toggleUserStatus('@user.Id', @user.IsActive.ToString().ToLower())"
                                                        title="@(user.IsActive ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                                    <i class="fas @(user.IsActive ? "fa-lock" : "fa-unlock")"></i>
                                                </button>
                                                <button type="button"
                                                        class="btn btn-sm btn-danger"
                                                        onclick="deleteUser('@user.Id')" title="Xóa">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#userTable').DataTable({
                destroy: true,
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/vi.json'
                },
                columnDefs: [
                    { orderable: false, targets: [4, 5] }, // Disable sort for Roles and Actions
                    { type: 'date', targets: 2 } // Format date column
                ],
                order: [[2, 'desc']], // Sort by Created At descending
                pageLength: 25,
                responsive: true,
                lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'Tất cả']],
                dom: '<"row mb-3"<"col-md-6"l><"col-md-6"f>>t<"row mt-3"<"col-md-6"i><"col-md-6"p>>'
            });
        });

        function toggleUserStatus(userId, currentStatus) {
            if (confirm('Bạn có chắc chắn muốn ' + (currentStatus ? 'khóa' : 'mở khóa') + ' người dùng này?')) {
                $.post('@Url.Action("ToggleUserStatus", "Admin")', { id: userId }, function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + response.message);
                    }
                });
            }
        }

        function deleteUser(userId) {
            if (confirm('Bạn có chắc chắn muốn xóa người dùng này?')) {
                $.post('@Url.Action("DeleteUser", "Admin")', { id: userId }, function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + response.message);
                    }
                });
            }
        }
    </script>
}